#include <iostream>
#include <string>
#include <vector>
using namespace std;

// ===================== Animal hierarchy =====================
class Animal {
private:
    int age;
    bool isFemale;
    int id;
    static int nextId;

public:
    Animal() {
        age = 0;
        isFemale = false;
        id = nextId++;
    }

    Animal(int animalAge, bool female) {
        age = animalAge;
        isFemale = female;
        id = nextId++;
    }

    void setAge(int animalAge) {
        age = animalAge;
    }

    void setGender(bool female) {
        isFemale = female;
    }

    int getAge() const {
        return age;
    }

    bool getGender() const {
        return isFemale;
    }

    int getId() const {
        return id;
    }

    void increaseAge() {
        age++;
    }

    virtual int getBirthRate() const {
        return 0;
    }

    virtual string getSpecies() const {
        return "Animal";
    }

    virtual string getType() const {
        return "Animal";
    }

    virtual void displayAnimal() const {
        cout << "Animal #" << id << ": I am a ";
        if (isFemale) {
            cout << "female ";
        }
        else {
            cout << "male ";
        }
        cout << getSpecies() << ", " << age << " month(s) old" << endl;
    }

    virtual ~Animal() {}
};

int Animal::nextId = 1;

class Mammal : public Animal {
private:
    int birthRateMonths;

public:
    Mammal() : Animal() {
        birthRateMonths = 12;
    }

    Mammal(int animalAge, bool female) : Animal(animalAge, female) {
        birthRateMonths = 12;
    }

    int getBirthRate() const override {
        return birthRateMonths;
    }

    string getType() const override {
        return "Mammal";
    }
};

class Cat : public Mammal {
public:
    Cat() : Mammal() {}
    Cat(int animalAge, bool female) : Mammal(animalAge, female) {}

    string getSpecies() const override {
        return "cat";
    }
};

class Dog : public Mammal {
public:
