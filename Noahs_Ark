// this is starting our ark with 12 animals (and thats all it is)
//this vector is storing pointers specifically to Animal objects (addresses/indirectly)
//the & allows the main function to be updated and not just a copy of the main function
//there are two of each for male and female
//push_back is what pushes each to the END of the vector
void buildArk(vector<Animal*>& ark) {
    ark.push_back(new Cat(0, true));
    ark.push_back(new Cat(0, false));
    ark.push_back(new Dog(0, true));
    ark.push_back(new Dog(0, false));
    ark.push_back(new Eagle(0, true));
    ark.push_back(new Eagle(0, false));
    ark.push_back(new Parakeet(0, true));
    ark.push_back(new Parakeet(0, false));
    ark.push_back(new Goldfish(0, true));
    ark.push_back(new Goldfish(0, false));
    ark.push_back(new Shark(0, true));
    ark.push_back(new Shark(0, false));
}
//just like the function above, its pointing to Animal and updating main, not making a copy

void checkInventory(const vector<Animal*>& ark) {
    cout << "\n===== INVENTORY =====\n";
    //starting at beginning of index (0) and keep looping until we reach the end which is however
    //many animals are in the ark
    //int was put in to make sure the data types stay the same
    for (int i = 0; i < (int)ark.size(); i++) {
        //this is saying to go to animal pointer in index i and call displayAnimal()
        ark[i]->displayAnimal();
    }
    cout << "Total animals: " << ark.size() << endl;
}
//we must clean up the ark function at the end so it doesnt just store all the data.
//this goes through each index and clears it
void cleanUpArk(vector<Animal*>& ark) {
    for (int i = 0; i < (int)ark.size(); i++) {
        delete ark[i];
    }
    ark.clear();
}
// Create one baby based on species
Animal* makeBaby(string species, bool female) {
    if (species == "cat") {
        return new Cat(0, female);
    }
    else if (species == "dog") {
        return new Dog(0, female);
    }
    else if (species == "eagle") {
        return new Eagle(0, female);
    }
    else if (species == "parakeet") {
        return new Parakeet(0, female);
    }
    else if (species == "goldfish") {
        return new Goldfish(0, female);
    }
    else if (species == "shark") {
        return new Shark(0, female);
    }
    return nullptr;
}
// Process one month: age animals and handle births
void processMonth(vector<Animal*>& ark) {
    //stores how many animals were in the ark before the month passed
    //this allows to only loop through animals that were at the start of the month
    int originalSize = ark.size();
    //takes the animal at a certain postion in the index and adds 1 month to its age
    for (int i = 0; i < originalSize; i++) {
        ark[i]->increaseAge();
        //we check the gender to make sure its female, and only then will it keep going to give birth if thats whats next
        if (ark[i]->getGender() == true) {
            //this checks if the female is within the time frame of giving birth by checking if itd age is a 
            //multiple of its birth rate
            int birthRate = ark[i]->getBirthRate();
            if (birthRate > 0 && ark[i]->getAge() % birthRate == 0) {
                //this will make every other baby female depending on the amount of animals in the ark
                bool babyIsFemale = (ark.size() % 2 == 0);
                //this creates a baby the same species as its mother
                Animal* baby = makeBaby(ark[i]->getSpecies(), babyIsFemale);
                //this points to nothing, but will only continue if a valid object was created
                if (baby != nullptr) {
                    //adds new baby to end of vector
                    ark.push_back(baby);
                    cout << "A new " << ark[i]->getSpecies() << " was born!" << endl;
                }
            }
        }
    }
}
// ===================== Main with menu =====================
int main() {
    vector<Animal*> ark;
    buildArk(ark);
    int choice = 0;
    int months = 11;
    //Options menu thingy
    while (choice != 4) {
        cout << "\n=================================\n";
        cout << "You have been on the ark for " << months << " months.\n";
        cout << "Would you like to:\n";
        cout << "1 - Let another month pass\n";
        cout << "2 - Skip a year\n";
        cout << "3 - Look inside Ark\n";
        cout << "4 - Quit\n";
        cout << "What do you want to do?\n";
        cin >> choice;
        switch (choice) {
        case 1:
            months++;
            processMonth(ark);
            break;
        case 2:
            for (int i = 0; i < 12; i++) {
                months++;
                processMonth(ark);
            }
            break;
        case 3:
            checkInventory(ark); // displays all animals in Noah's Ark
            break;
        case 4:
            cout << "\nDone (:\n";
            break;
        default:
            cout << "\nlol what are you doing here?\n";
        }
    }
    cleanUpArk(ark); // clears the Noah's Ark
    return 0;
}
