void buildArk(vector<Animal*>& ark) {
    ark.push_back(new Cat(0, true));
    ark.push_back(new Cat(0, false));

    ark.push_back(new Dog(0, true));
    ark.push_back(new Dog(0, false));

    ark.push_back(new Eagle(0, true));
    ark.push_back(new Eagle(0, false));

    ark.push_back(new Parakeet(0, true));
    ark.push_back(new Parakeet(0, false));

    ark.push_back(new Goldfish(0, true));
    ark.push_back(new Goldfish(0, false));

    ark.push_back(new Shark(0, true));
    ark.push_back(new Shark(0, false));
}

void checkInventory(const vector<Animal*>& ark) {
    for (int i = 0; i < ark.size(); i++) {
        ark[i]->displayAnimal();
    }
}

void cleanUpArk(vector<Animal*>& ark) {
    for (int i = 0; i < ark.size(); i++) {
        delete ark[i];
    }

    ark.clear();
}

int main() {
    vector<Animal*> ark;

    buildArk(ark);

    cout << "Starting inventory:" << endl;
    checkInventory(ark);

    cleanUpArk(ark);

    return 0;
}
