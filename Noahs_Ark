#include<iostream>
#include<string>
#include<iomanip>
using namespace std;

class Animal {
private:
	//nextId allows me to give each animal a unique ID
	//static int allows all animals to share the same "nextID" within this class
	int age;
	bool issaFemale;
	int id;
	static int nextId;
public:
	// this is my default constructor
	Animal() {
		age = 0;
		issaFemale = false;
		id = nextId;
		nextId++;
	}

	//Constructor with values
	Animal(int animalAge, bool female) {
		age = animalAge;
		issaFemale = female;
		id = nextId;
		nextId;
	}

	//setters
	void setAge(int animalAge) {
		age = animalAge;
	}

	void setGender(bool female) {
		issaFemale = female;
	}

	//getters
	int getAge() const {
		return age;
	}

	bool getGender() const {
		return issaFemale;
	}

	int getId() const {
		return id;
	}

	//adds 1 month to age
	void ageIncrease() {
		age++;
	}
	//Animal info display
	void animalDisplay() const {
		cout << "Animal ID: " << id << endl;
		cout << "Age: " << age << " months" << endl;
		cout << "Gender: ";

		if (issaFemale) {
			cout << "Female" << endl;
		}
		else {
			cout << "Male" << endl;
		}
	}
};

//because I have a static variable, I MUST define it outside the class
int Animal::nextId = 1;

//here is my mammal subclass
class Mammal : public Animal {
private:
	int birthRates;

public:
	//default constructor for subclass
	Mammal() : Animal() {
		birthRates = 12;
	}

	//subclass constructor with values
	Mammal(int animalAge, bool female) : Animal(animalAge, female) {
		birthRates = 12;
	}

	int getbirthRate() const {
		return birthRates;
	}

	void mammalDisplay() const {
		animalDisplay();
		cout << "Animal Type: Mammal" << endl;
		cout << "Birth Rate: " << birthRates << "months" << endl;
	}

};

class Bird : public Animal {
private:
	int birthRateMonths;
public:
	Bird() : Animal() {
		birthRateMonths = 9;
	}

	Bird(int animalAge, bool female) : Animal(animalAge, female) {
		birthRateMonths = 9;
	}

	int getbirthRate() const {
		return birthRateMonths;
	}

	void birdDisplay() const {
		animalDisplay();
		cout << "Animal Type: Bird" << endl;
		cout << "Birth rate: " << birthRateMonths << " months" << endl;
	}
};
